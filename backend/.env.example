PORT=5000
FRONTEND_URL=http://localhost:5173

# PostgreSQL (use same settings in pgAdmin 4)
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=tirth_portfolio
PG_USER=postgres
PG_PASSWORD=your_postgres_password
PG_SSL=false

# Or single connection string (overrides PG_* if set):
# DATABASE_URL=postgresql://postgres:your_password@localhost:5432/tirth_portfolio

# Nodemailer / SMTP (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="Tirth Portfolio" <your-email@gmail.com>
CONTACT_EMAIL=tirthvadariya@example.com
